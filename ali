
<!DOCTYPE html>
<html>
  <head>
    <title>Registration form with alert</title>
  </head>
  
  <body>
    <form id="Registrationforms">
      
    <div class="form-group">
      <h2> Full Name: </h2>
         <input type="text" id="nameInput" placeholder= "Enter your full name">
         <button onclick="enterName()">Enter</button>
         <div class="output" id="greeting"></div>
    </div>
    <div class= "form-group">
       <div class="radio-group">
       <input type= "radio" name="gender" value="female" id="female">
       <label for="female"> female</label>
       
       <input type= "radio" name="gender" value="male" id="male">
       <label for="female"> male</label>
      
       <input type= "radio" name="gender" value="Other" id="other">
       <label for="Other"> Other</label>
       </div>
    </div>  
    
    <div class="form-group">
        <label for="country">Country: </label>
        <select id="country">
          <option value="">select a country</option>
          <option value="USA">United States</option>
          <option value="Canada">Canada</option>
          <option value="UK">United kingdom</option>
          <option value="Australia">Australia</option>
          <option value="India">India</option>
          <option value="Philippines">Philippines</option>
          <option value="Other">Other</option>
        </select>
        
        <script>
          
          function getFormValues(){
              let fullName = document.getElementById("fullName").value;
              let email = document.getElementById("email").value;
              let password = document.getElementById("password").value;
              let confirmPassword = document.getElementById("confirmPassword").value;
              let age = document.getElementById("age").value;
              
              let gender = "";
              if (document.getElementById("male").checked) {
                  gender = "Male";
              }else if (document.getElementById("female").checked) {
                  gender = "Female";
              }else if (document.getElementById("other").checked) {
                gender = "Other";
              }
              
              let country = document.getElementById("country").value;
              let termAccepted = document.getElementById("terms").checked;
              
              return {
                fullName: fullName,
                email: email,
                password: password,
                confirmPassword: confirmPassword,
                age: age,
                gender: gender,
                country: country,
                termsAccepted: termsAccepted
          };
        }
          function validationForm() {
            let values = getElementById();
            let errors = [];
            
            if (values.fullName === "") {
                errors.push("Full name is required");
            }
            
            if (values.email === "") {
                errors.push("Email is required");
            } else if (values.email.includes("@") || !values.email.includes(".")) {
                errors.push("Please enter a valid email address");
            }
            
            if (values.password === "") {
                errors.push("Password is required");
            } else if (values.password.length < 6) {
                errors.push("Password must be at least 6 characters");
            }
            
            if (values.Password !== values.confirmPassword) {
                errors.push("Passwords do not match");
            }
            
            if (values.age === "") {
                errors.push("Age is required");
            } else if (values.age < 18 || values.age > 120) {
                errors.push("Age must be between 18 and 120");
            }   
            if (values.gender === "") {
                errors.push("Please select a gender");
            }
            
            if (values.country === "") {
                errors.push("Please select a country");
            }
            
            if (!values.termsAccepted) {
                errors.push("You must accept the Terms and Condition");
            }
            
            return errors;
            
          }
          
          function registration() {
            let errors = validationForm();
            
            if (errors.length > 0) {
              //Display error on package
              let errorHTML = "<strong> Please fix the following errors: </strong><br>"
              for (let i = 0; i < errors.length; i++) {
                  errorHTML += "" + errors[i] + "<br>";
              }
              document.getElementById("errorMessages").innerHTML = errorHTML;
              
              // Show alert with errors
              alert("Validation Errors; \n\n " + erroes.join(\n "));
              
              
              //Log errors to console
              console.log("Registration failed with errors");
              console.log("errors");
            } else{
              let values = getFormValues();
              
              //Create Registration summary
              let registrationSummary =
              " REGISTRATION SUCCESSFUL!\n\n" +
              "__________________________\n" +
              "USER INFORMATION\n" +
              "__________________________\n" +
              "Full name: "+ values.fullName + "\n" +
              "Email: " + values.email + "\n" +
              "Age: " + values.age + "\n" +
              "Gender" + values.gender + "\n" +
              "Country" + values.country + "\n" +
              "Terms Accepted" + (values.termsAccepted ? "Yes" :"No") + "\n" +
              "__________________________\n\n" +
              "Welcome, " + values.fullName + "!" ;
              
            //Show alert with registration info 
            alert(registrationSummary);
            
            //log to console
            console.log("Name:", values.fullName);
            console.log("Email:", values.email);
            console.log("Age:", values.age);
            console.log("Gender:", values.gender);
            console.log("Country:", values.country);
            
            //show success message on page
            document.getElementById("errorMessages").innerHTML =
                "<span style='color: green; font-weight: bold;'> Registration successful!
            }
          
        function clearForm() {
          //clear all inputs
          document.getElementById("fullName").value ="";
          document.getElementById("email").value ="";
          document.getElementById("password").value ="";
          document.getElementById("confirmPassword").value ="";
          document.getElementById("age").value ="";
          
          //clear radip buttons
          document.getElementById("male").checked = false;
          document.getElementById("female").checked = false;
          document.getElementById("other").checked = false;
          
          //reset dropdown
          document.getElementById("country").value = "";
          
          //uncheck terms
          document.getElementById("terms").checked = false;
          
          //clear error messages
          document.getElementById("errorMessages").innerHTML= "";
          document.getElementById("passwordMatchMessage").innerHTML= "";
          
          //show alert 
          alert ("Form has been cleared!");
          
        }
        
        function checkPasswordMatch(){
          let password = document.getElementById("password").value;
          let confirmPassword = document.getElementById("confirmPassword").value;
          let messageDiv = document.getElementById("passwordMatchMessage");
          
          if (confirmPassword === "") {
              messageDiv.innerHTML = "";
          }else if (password === confirmPassword) {
              messageDiv.innerHTML = "Password match";
              messageDiv.style.color ="green";
          }else{
              messageDiv.innerHTML ="Password do not match";
              messageDiv.style.color ="red";
          }
        }
          
        //add event listener for real-time password check
        document.getElementById("password").addEventListener("keyup", checkPasswordMatch);
        document.getElementById("confirmPassword").addEventListener("keyup", checkPasswordMatch);
        
            
            
                
              
            
             
          
        </script>
    </div>
    
    
      
      
      
    
  </body>
    

</html>      
